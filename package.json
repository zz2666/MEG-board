{
  "name": "earnings-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx -r tsconfig-paths/register scripts/seed-companies.ts",
    "extract:source": "tsx -r tsconfig-paths/register scripts/extract-official-source.ts",
    "import:akshare": "tsx -r tsconfig-paths/register scripts/import-akshare.ts",
    "import:earnings": "tsx -r tsconfig-paths/register scripts/import-earnings.ts",
    "parser:plan": "tsx -r tsconfig-paths/register scripts/list-parser-plan.ts",
    "snapshot:repair": "tsx -r tsconfig-paths/register scripts/repair-snapshot.ts",
    "snapshot:akshare": "npm run import:akshare -- --all --snapshot",
    "snapshot:earnings": "npm run import:earnings -- --implemented --snapshot"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
